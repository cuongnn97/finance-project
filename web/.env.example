# Supabase (client-side — safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# App
VITE_APP_NAME=FinanceOS
VITE_APP_URL=https://your-app.vercel.app

# Telegram bot username (shown on Profile page button)
VITE_TELEGRAM_BOT_USERNAME=your_bot_username

# ── Server-side env vars (Vercel API routes / bot webhook) ──
# Supabase service role key (bypasses RLS — NEVER expose to browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Telegram bot token (NEVER expose to browser)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
